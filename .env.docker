# Docker 环境变量配置
# 复制此文件为 .env 并修改配置

# Flask 配置
SECRET_KEY=your-random-secret-key-change-this-in-production
FLASK_ENV=production

# 代理配置
USE_PROXY=true
MIN_PROXIES=10
MAX_PROXIES=50

# AI 配置（可选）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 数据库配置（docker-compose 会自动配置，无需修改）
# DATABASE_URL=postgresql://wjx_user:wjx_password_2024@postgres:5432/wjx_survey
